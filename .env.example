# ===== Server =====
PORT=3000
API_BASE_URL=http://localhost:3000
NODE_ENV=development
JWT_SECRET=change-me

# ===== OTP / SMS (لا تغيّر المزوّد فقط قيود) =====
SMS_PROVIDER=current
OTP_TTL_MIN=5
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_PER_15M=3

# ===== Maps (بدون Google) =====
MAP_PROVIDER=leaflet
OSM_ROUTING_URL=https://router.project-osrm.org/route/v1
NOMINATIM_URL=https://nominatim.openstreetmap.org

# ===== Payments (Paymob) =====
PAY_PROVIDER=paymob
PAYMOB_API_KEY=
PAYMOB_INTEGRATION_ID_CARD=
PAYMOB_IFRAME_ID=
PAYMOB_HMAC_SECRET=
PAYMOB_BASE=https://accept.paymob.com

# ===== CORS =====
CORS_ORIGINS=http://localhost:3000
